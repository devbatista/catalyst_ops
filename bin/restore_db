#!/usr/bin/env bash

set -euo pipefail

APP_DIR="${APP_DIR:-/opt/catalyst_ops}"
COMPOSE_FILE="${COMPOSE_FILE:-$APP_DIR/docker-compose.yml}"
BACKUP_FILE="${1:-${BACKUP_FILE:-}}"
TARGET_DB="${TARGET_DB:-}"
CONFIRM="${CONFIRM_RESTORE:-}"

if [ -z "$BACKUP_FILE" ]; then
  echo "[restore_db] Uso: bin/restore_db /caminho/arquivo.dump"
  echo "[restore_db] Ou use BACKUP_FILE=/caminho/arquivo.dump"
  exit 1
fi

if [ ! -f "$BACKUP_FILE" ]; then
  echo "[restore_db] Arquivo de backup nao encontrado: $BACKUP_FILE"
  exit 1
fi

if [ "$CONFIRM" != "yes" ]; then
  echo "[restore_db] Operacao destrutiva. Defina CONFIRM_RESTORE=yes para continuar."
  exit 1
fi

cd "$APP_DIR"

if [ ! -f "$COMPOSE_FILE" ]; then
  echo "[restore_db] docker-compose.yml nao encontrado em: $COMPOSE_FILE"
  exit 1
fi

echo "[restore_db] Iniciando restore a partir de: $BACKUP_FILE"

run_restore() {
  docker compose exec -T "$@" db sh -lc '
    set -e
    : "${POSTGRES_USER:?POSTGRES_USER nao definido no container db}"
    : "${POSTGRES_PASSWORD:?POSTGRES_PASSWORD nao definido no container db}"
    : "${POSTGRES_DB:?POSTGRES_DB nao definido no container db}"

    export PGPASSWORD="$POSTGRES_PASSWORD"
    DB_TO_RESTORE="${TARGET_DB:-$POSTGRES_DB}"

    if ! psql -h 127.0.0.1 -U "$POSTGRES_USER" -d postgres -tAc "SELECT 1 FROM pg_database WHERE datname='\''$DB_TO_RESTORE'\''" | grep -q 1; then
      createdb -h 127.0.0.1 -U "$POSTGRES_USER" "$DB_TO_RESTORE"
    fi

    pg_restore \
      -h 127.0.0.1 \
      -U "$POSTGRES_USER" \
      -d "$DB_TO_RESTORE" \
      --clean \
      --if-exists \
      --no-owner \
      --no-privileges \
      -v
  ' < "$BACKUP_FILE"
}

if [ -n "$TARGET_DB" ]; then
  run_restore -e TARGET_DB="$TARGET_DB"
else
  run_restore
fi

echo "[restore_db] Restore concluido com sucesso."
