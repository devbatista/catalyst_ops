events {}

http {
  resolver 127.0.0.11 valid=10s ipv6=off;
  resolver_timeout 5s;

  # Mitiga 502 por headers grandes (ex.: Set-Cookie/session)
  client_header_buffer_size 16k;
  large_client_header_buffers 8 32k;
  proxy_buffer_size 128k;
  proxy_buffers 8 128k;
  proxy_busy_buffers_size 256k;

  server {
    listen 80;
    server_name catalystops.com.br *.catalystops.com.br;

    location / {
      return 301 https://$host$request_uri;
    }
  }

  server {
    listen 443 ssl http2;
    server_name catalystops.com.br *.catalystops.com.br;

    ssl_certificate     /etc/letsencrypt/live/app.catalystops.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.catalystops.com.br/privkey.pem;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    location /assets/ {
      set $upstream web:3000;
      proxy_pass http://$upstream;
      proxy_set_header Host $host;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
      set $upstream web:3000;
      proxy_pass http://$upstream;
      proxy_set_header Host $host;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-Proto $scheme;
    }
  }
}
