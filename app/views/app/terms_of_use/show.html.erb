<div class="page-wrapper">
  <div class="page-content">
    <% flash.each do |type, message| %>
      <% bootstrap_class = { notice: "alert-success", alert: "alert-danger", error: "alert-danger" }[type.to_sym] || "alert-info" %>
      <div class="alert <%= bootstrap_class %> alert-dismissible fade show" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>

    <div class="row justify-content-center">
      <div class="col-12 col-xl-9">
        <div class="card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <div>
                <h4 class="mb-1"><%= TermsOfUse.title %></h4>
                <p class="text-muted mb-0">Empresa: <%= @company.name %></p>
              </div>
              <span class="badge bg-light text-dark">Versão <%= TermsOfUse.current_version %></span>
            </div>

            <div class="border rounded p-3 bg-light mb-4" style="max-height: 420px; overflow-y: auto;">
              <%= render "shared/terms_of_use_content" %>
            </div>

            <%= form_with url: app_terms_of_use_path, method: :patch, local: true do |f| %>
              <div class="form-check mb-3">
                <%= check_box_tag :accept_terms, "1", false, class: "form-check-input", id: "accept_terms_required" %>
                <%= label_tag :accept_terms_required, "Li e aceito o Contrato de Utilização vigente.", class: "form-check-label" %>
              </div>

              <div class="d-flex justify-content-end">
                <%= f.submit "Aceitar e continuar", class: "btn btn-primary" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
