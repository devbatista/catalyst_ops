<div class="page-wrapper">
  <div class="page-content">
    <div class="row">
      <div class="col-12">
        <div class="mb-3">
          <h4 class="mb-0 text-uppercase">Informações do cliente</h6>
        </div>
        <div class="card">
          <div class="card-body">
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Nome:</strong>
                <p><%= @client.name %></p>
              </div>
              <div class="col-md-3">
                <strong>Documento:</strong>
                <p><%= @client.formatted_document %></p>
              </div>
              <div class="col-md-3">
                <strong>Telefone:</strong>
                <p><%= @client.formatted_phone %></p>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Email:</strong>
                <p><%= @client.email %></p>
              </div>
              <div class="col-md-6">
                <strong>Empresa:</strong>
                <p><%= @client.company&.name %></p>
              </div>
            </div>
            <% if @client.addresses.any? %>
            <hr>
            <h5>Endereço</h5>
            <% @client.addresses.each do |address| %>
            <div class="row mb-2">
              <div class="col-md-4">
                <strong>CEP:</strong>
                <p><%= address.zip_code %></p>
              </div>
              <div class="col-md-4">
                <strong>Rua:</strong>
                <p><%= address.street %>, <%= address.number %></p>
              </div>
              <div class="col-md-4">
                <strong>Bairro:</strong>
                <p><%= address.neighborhood %></p>
              </div>
            </div>
            <div class="row mb-2">
              <div class="col-md-3">
                <strong>Cidade:</strong>
                <p><%= address.city %></p>
              </div>
              <div class="col-md-2">
                <strong>Estado:</strong>
                <p><%= address.state %></p>
              </div>
              <div class="col-md-3">
                <strong>Complemento:</strong>
                <p><%= address.complement %></p>
              </div>
              <div class="col-md-4">
                <strong>Tipo:</strong>
                <p><%= address.address_type %></p>
              </div>
            </div>
            <% end %>
            <% end %>

            <hr>
            <h5>Ordens de Serviço</h5>

            <%= form_with url: app_client_path(@client), method: :get, local: true, class: "row g-2 mb-3" do %>
              <div class="col-12 col-md-4">
                <input type="text" name="os_q" value="<%= params[:os_q] %>" class="form-control" placeholder="Título da OS">
              </div>
              <div class="col-12 col-md-2">
                <input type="text" name="os_code" value="<%= params[:os_code] %>" class="form-control" placeholder="Código">
              </div>
              <div class="col-12 col-md-3">
                <select name="os_status" class="form-select">
                  <option value="">Todos os status</option>
                  <% @order_service_statuses.each do |status| %>
                    <option value="<%= status %>" <%= params[:os_status] == status ? "selected" : "" %>><%= status.humanize %></option>
                  <% end %>
                </select>
              </div>
              <div class="col-12 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
                <%= link_to "Limpar", app_client_path(@client), class: "btn btn-outline-secondary w-100" %>
              </div>
            <% end %>

            <% if @order_services.any? %>
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th>Código</th>
                      <th>Título</th>
                      <th>Status</th>
                      <th>Agendada</th>
                      <th>Técnicos</th>
                      <th class="text-end">Ações</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @order_services.each do |os| %>
                      <tr>
                        <td class="fw-semibold"><%= os.code %></td>
                        <td><%= os.title %></td>
                        <td>
                          <span class="badge bg-<%= os.status_color %>"><%= os.status.humanize %></span>
                        </td>
                        <td><%= os.scheduled_at.present? ? l(os.scheduled_at, format: :short) : "-" %></td>
                        <td><%= os.users.map(&:name).join(", ").presence || "-" %></td>
                        <td class="text-end">
                          <div class="d-inline-flex gap-1">
                            <%= link_to "Ver", app_order_service_path(os), class: "btn btn-sm btn-outline-primary" %>
                            <%= link_to "Editar", edit_app_order_service_path(os), class: "btn btn-sm btn-outline-secondary" %>
                          </div>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <p>Nenhuma ordem de serviço encontrada para os filtros aplicados.</p>
            <% end %>

            <div class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
              <div class="d-flex gap-2">
                <%= link_to "Voltar", app_clients_path, class: "btn btn-secondary" %>
                <%= link_to "Editar", edit_app_client_path(@client), class: "btn btn-primary" %>
              </div>
              <% if current_user.can_create_orders? %>
                <%= link_to "Novo Orçamento", new_app_order_service_path(client_id: @client.id), class: "btn btn-success ms-auto" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
