<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white py-3">
    <h5 class="card-title mb-0">Assinatura</h5>
  </div>
  <div class="card-body p-4">
    <% subscription = current_user.company.current_subscription %>
    <% if subscription && subscription.plan %>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Plano:</strong></div>
        <div class="col-md-8"><%= subscription.plan.name %></div>
      </div>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Status:</strong></div>
        <div class="col-md-8">
          <span class="badge bg-<%= subscription_badge_class(subscription.status) %>">
            <%= subscription.status.humanize %>
          </span>
        </div>
      </div>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Início:</strong></div>
        <div class="col-md-8"><%= l(subscription.start_date, format: :short) if subscription.start_date %></div>
      </div>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Fim:</strong></div>
        <div class="col-md-8"><%= l(subscription.end_date, format: :short) if subscription.end_date %></div>
      </div>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Valor:</strong></div>
        <div class="col-md-8">
          <%= number_to_currency(subscription.plan.transaction_amount, unit: "R$") if subscription.plan.transaction_amount %>
        </div>
      </div>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Forma de pagamento:</strong></div>
        <div class="col-md-8"><%= subscription.company.payment_method || "Não especificado" %></div>
      </div>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Limite de Técnicos:</strong></div>
        <div class="col-md-8"><%= subscription.plan.max_technicians || "Ilimitado" %></div>
      </div>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Limite de Ordens:</strong></div>
        <div class="col-md-8"><%= subscription.plan.max_orders || "Ilimitado" %></div>
      </div>
      <div class="row mb-2">
        <div class="col-md-4 text-secondary"><strong>Limite de Orçamentos:</strong></div>
        <div class="col-md-8"><%= subscription.plan.max_budgets || "Ilimitado" %></div>
      </div>
      <div class="row mb-0">
        <div class="col-md-4 text-secondary"><strong>Tipo de suporte:</strong></div>
        <div class="col-md-8"><%= subscription.plan.support_level %></div>
      </div>

      <hr class="my-4">
      <h6 class="mb-3">Cancelamento</h6>

      <% if subscription.cancel_at_period_end? %>
        <div class="alert alert-warning mb-3">
          Cancelamento agendado para <strong><%= l(subscription.cancel_effective_on, format: :short) %></strong>.
          A assinatura continuará ativa até essa data.
        </div>

        <%= button_to "Reativar renovação",
          resume_subscription_app_configurations_path,
          method: :patch,
          class: "btn btn-outline-success" %>
      <% else %>
        <p class="text-muted mb-3">
          Você pode solicitar o cancelamento e continuar com acesso até o fim do período vigente.
        </p>

        <%= form_with url: cancel_subscription_app_configurations_path, method: :patch, local: true do %>
          <div class="mb-3">
            <label class="form-label fw-semibold">Motivo do cancelamento (opcional)</label>
            <textarea name="cancel_reason" rows="2" class="form-control" placeholder="Ex.: reestruturação interna, pausa de operação, etc."></textarea>
          </div>
          <button type="submit" class="btn btn-outline-danger" data-confirm="Deseja cancelar a assinatura ao fim do período vigente?">
            Cancelar assinatura no fim do período
          </button>
        <% end %>
      <% end %>
    <% else %>
      <div class="alert alert-warning mb-0">
        Nenhuma assinatura ativa encontrada para sua empresa.
      </div>
    <% end %>
  </div>
</div>
