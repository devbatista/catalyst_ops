<%= form_with model: company, url: update_company_app_configurations_path, method: :patch, local: true do |f| %>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Razão Social</h6></div>
    <div class="col-sm-9"><%= f.text_field :name, class: "form-control" %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">CNPJ/CPF</h6></div>
    <div class="col-sm-9"><%= f.text_field :document, class: "form-control", value: company.formatted_document, readonly: true, disabled: true %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">E-mail</h6></div>
    <div class="col-sm-9"><%= f.email_field :email, class: "form-control" %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Telefone</h6></div>
    <div class="col-sm-9"><%= f.text_field :phone, class: "form-control", data: { mask: "phone" } %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Rua</h6></div>
    <div class="col-sm-9"><%= f.text_field :street, class: "form-control" %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Número</h6></div>
    <div class="col-sm-9"><%= f.text_field :number, class: "form-control" %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Complemento</h6></div>
    <div class="col-sm-9"><%= f.text_field :complement, class: "form-control" %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Bairro</h6></div>
    <div class="col-sm-9"><%= f.text_field :neighborhood, class: "form-control" %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Cidade</h6></div>
    <div class="col-sm-9"><%= f.text_field :city, class: "form-control" %></div>
  </div>
  <div class="row mb-3 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Estado</h6></div>
    <div class="col-sm-9"><%= f.text_field :state, class: "form-control" %></div>
  </div>
  <div class="row mb-4 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">CEP</h6></div>
    <div class="col-sm-9"><%= f.text_field :zip_code, class: "form-control", data: { mask: "cep" } %></div>
  </div>
  <div class="row mb-4 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Permitir OS sem orçamento</h6></div>
    <div class="col-sm-9">
      <div class="form-check">
        <%= f.check_box :allow_order_service_without_budget, class: "form-check-input", disabled: !company_responsible? %>
        <%= f.label :allow_order_service_without_budget, "A empresa pode criar ordem de serviço sem orçamento prévio", class: "form-check-label" %>
      </div>
      <% unless company_responsible? %>
        <small class="text-muted">Somente o responsável da empresa pode alterar essa configuração.</small>
      <% end %>
    </div>
  </div>
  <div class="row mb-4 align-items-center">
    <div class="col-sm-3"><h6 class="mb-0 text-secondary">Permitir OS simultâneas</h6></div>
    <div class="col-sm-9">
      <div class="form-check">
        <%= f.check_box :allow_simultaneous_order_services, class: "form-check-input", disabled: !company_responsible? %>
        <%= f.label :allow_simultaneous_order_services, "A empresa pode atribuir o mesmo técnico em OS com horários sobrepostos", class: "form-check-label" %>
      </div>
      <% unless company_responsible? %>
        <small class="text-muted">Somente o responsável da empresa pode alterar essa configuração.</small>
      <% end %>
    </div>
  </div>
  <div class="row">
    <div class="col-sm-3 d-none d-sm-block"></div>
    <div class="col-sm-9">
      <%= f.submit "Salvar alterações", class: "btn btn-success px-4" %>
    </div>
  </div>
<% end %>

<%= javascript_include_tag "viacep" %>
<%= javascript_import_module_tag "app/company_form" %>
