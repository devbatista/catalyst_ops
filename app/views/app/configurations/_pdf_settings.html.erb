<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3">
    <h5 class="card-title mb-0">Personalização dos PDFs</h5>
  </div>
  <div class="card-body p-4">
    <% unless company.pdf_customization_available? %>
      <div class="alert alert-warning mb-0">
        A personalização dos PDFs está disponível apenas nos planos Profissional e Enterprise.
      </div>
    <% else %>
      <div class="row g-4">
        <div class="col-12">
          <%= render "pdf_settings_form",
                     title: "Ordem de Serviço",
                     pdf_setting: company.pdf_setting_or_default("order_service"),
                     description_label: "Descrição do serviço",
                     items_label: "Itens de serviço",
                     show_observations_controls: true %>
        </div>

        <div class="col-12">
          <%= render "pdf_settings_form",
                     title: "Orçamento",
                     pdf_setting: company.pdf_setting_or_default("budget"),
                     description_label: "Descrição do orçamento",
                     items_label: "Itens do orçamento",
                     show_observations_controls: false %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener("change", function(event) {
    if (!event.target.classList.contains("pdf-customization-toggle")) return;

    var target = document.getElementById(event.target.dataset.target);
    if (!target) return;

    target.classList.toggle("d-none", !event.target.checked);

    var status = event.target.closest(".pdf-toggle-wrap").querySelector(".pdf-toggle-status");
    if (status) status.textContent = event.target.checked ? "Ativo" : "Inativo";
  });
</script>
