<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
    <h5 class="card-title mb-0">Dados da Empresa</h5>
    <% if can?(:manage, Company) %>
      <%= link_to "Editar dados", "#", class: "btn btn-outline-primary btn-sm", data: { bs_toggle: "collapse", bs_target: "#editCompanyPanel" } %>
    <% end %>
  </div>
  <div class="card-body p-4">
    <div class="row mb-2">
      <div class="col-md-3 text-secondary"><strong>Razão Social:</strong></div>
      <div class="col-md-9"><%= current_user.company.name %></div>
    </div>
    <div class="row mb-2">
      <div class="col-md-3 text-secondary"><strong>CNPJ/CPF:</strong></div>
      <div class="col-md-9"><%= current_user.company.formatted_document %></div>
    </div>
    <div class="row mb-2">
      <div class="col-md-3 text-secondary"><strong>E-mail:</strong></div>
      <div class="col-md-9"><%= current_user.company.email %></div>
    </div>
    <div class="row mb-2">
      <div class="col-md-3 text-secondary"><strong>Telefone:</strong></div>
      <div class="col-md-9"><%= current_user.company.formatted_phone %></div>
    </div>
    <div class="row mb-0">
      <div class="col-md-3 text-secondary"><strong>Endereço:</strong></div>
      <div class="col-md-9"><%= current_user.company.full_address %></div>
    </div>
  </div>
</div>

<div class="collapse" id="editCompanyPanel">
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
      <h6 class="mb-0">Editar dados da empresa</h6>
    </div>
    <div class="card-body p-4">
      <%= render "company_data_form", company: current_user.company %>
    </div>
  </div>
</div>
