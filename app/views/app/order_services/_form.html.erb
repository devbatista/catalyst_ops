<div class="js-wait">
  <%= form_with(model: @order_service,
                url: @order_service.persisted? ? app_order_service_path(@order_service) : app_order_services_path,
                local: true) do |f| %>
    <% technician_edit_only = current_user.tecnico? && @order_service.persisted? %>
    <% show_discount_fields = @order_service.discount_type.to_s != "none" || @order_service.discount_value.to_d.positive? %>

    <div class="row g-4">
      <div class="col-12">
        <div class="border rounded-3 p-3 p-md-4">
          <h6 class="text-uppercase text-muted mb-3">Dados da OS</h6>
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.label :client_id, "Cliente", class: "form-label" %>
              <%= f.collection_select :client_id,
                                      @clients,
                                      :id,
                                      :name,
                                      { prompt: "Selecione o cliente" },
                                      class: "form-select",
                                      disabled: technician_edit_only %>
            </div>
            <% if @order_service.persisted? %>
              <div class="col-md-3">
                <%= f.label :scheduled_at, "Data agendada", class: "form-label" %>
                <%= f.text_field :scheduled_at,
                                 class: "form-control",
                                 type: "datetime-local",
                                 disabled: technician_edit_only,
                                 value: (@order_service.scheduled_at&.strftime("%Y-%m-%dT%H:%M") if @order_service.scheduled_at) %>
              </div>
              <div class="col-md-3">
                <%= f.label :expected_end_at, "Data prevista de término", class: "form-label" %>
                <%= f.text_field :expected_end_at,
                                 class: "form-control",
                                 type: "datetime-local",
                                 disabled: technician_edit_only,
                                 value: (@order_service.expected_end_at&.strftime("%Y-%m-%dT%H:%M") if @order_service.expected_end_at) %>
              </div>
            <% end %>
            <div class="col-12">
              <%= f.label :title, "Título", class: "form-label" %>
              <%= f.text_field :title, class: "form-control", disabled: technician_edit_only %>
            </div>
            <div class="col-12">
              <%= f.label :description, "Descrição", class: "form-label" %>
              <%= f.text_area :description, class: "form-control", rows: 3, disabled: technician_edit_only %>
            </div>
          </div>
        </div>
      </div>

      <% if @order_service.persisted? %>
        <div class="col-12">
          <div class="border rounded-3 p-3 p-md-4">
            <h6 class="text-uppercase text-muted mb-3">Execução e Anexos</h6>
            <div class="row g-3">
              <div class="col-12">
                <%= f.label :attachments, "Anexos", class: "form-label" %>
                <%= f.file_field :attachments, multiple: true, class: "form-control" %>
                <%= render partial: "app/order_services/attachments", locals: { order_service: @order_service } %>
              </div>
              <div class="col-12">
                <%= f.label :observations, "Observações", class: "form-label" %>
                <%= f.text_area :observations, class: "form-control", rows: 4, placeholder: "Registre detalhes importantes para a execução desta OS." %>
              </div>
              <div class="col-12">
                <%= f.label :user_ids, "Técnicos atribuídos", class: "form-label" %>
                <%= f.collection_select :user_ids,
                                        @technicians,
                                        :id,
                                        :name,
                                        {
                                          prompt: "Selecione os técnicos",
                                          selected: @order_service.user_ids
                                        },
                                        {
                                          multiple: true,
                                          class: "form-select",
                                          disabled: technician_edit_only,
                                          id: "multiple-select-field",
                                          data: { placeholder: "Escolha os técnicos" }
                                        } %>
              </div>
            </div>
          </div>
        </div>
      <% else %>
        <div class="col-12">
          <div class="alert alert-light border mb-0">
            Salve a ordem de serviço para anexar arquivos e atribuir técnicos.
          </div>
        </div>
      <% end %>

      <% if current_user.gestor? %>
        <% if @order_service.created_without_budget? %>
          <div class="col-12">
            <div class="border rounded-3 p-3 p-md-4">
              <h6 class="text-uppercase text-muted mb-3">Contexto da Criação Sem Orçamento</h6>
              <div class="row g-3">
                <div class="col-md-6">
                  <%= f.label :budget_waiver_reason, "Motivo (opcional)", class: "form-label" %>
                  <%= f.text_area :budget_waiver_reason, class: "form-control", rows: 2, placeholder: "Ex.: atendimento emergencial" %>
                </div>
                <div class="col-md-6">
                  <%= f.label :budget_waiver_authorized_by, "Autorizado por (opcional)", class: "form-label" %>
                  <%= f.text_field :budget_waiver_authorized_by, class: "form-control", placeholder: "Nome do responsável" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="col-12">
          <div class="border rounded-3 p-3 p-md-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
              <h6 class="text-uppercase text-muted mb-0">Financeiro</h6>
              <button class="btn btn-outline-secondary btn-sm"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#order-service-discount-fields"
                      aria-expanded="<%= show_discount_fields %>"
                      aria-controls="order-service-discount-fields">
                Aplicar desconto
              </button>
            </div>

            <div class="collapse <%= "show" if show_discount_fields %>" id="order-service-discount-fields">
              <div class="row g-3">
                <div class="col-md-3">
                  <%= f.label :discount_type, "Tipo de desconto", class: "form-label" %>
                  <%= f.select :discount_type,
                              options_for_select([["Sem desconto", "none"], ["Percentual (%)", "percent"], ["Valor fixo (R$)", "fixed"]], @order_service.discount_type),
                              {},
                              class: "form-select" %>
                </div>
                <div class="col-md-3">
                  <%= f.label :discount_value, "Valor do desconto", class: "form-label" %>
                  <%= f.number_field :discount_value, class: "form-control", min: 0, step: "0.01" %>
                </div>
                <div class="col-md-6">
                  <%= f.label :discount_reason, "Motivo do desconto", class: "form-label" %>
                  <%= f.text_field :discount_reason, class: "form-control", placeholder: "Ex.: negociação comercial" %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="border rounded-3 p-3 p-md-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
              <div>
                <h6 class="text-uppercase text-muted mb-1">Itens de Serviço</h6>
                <small class="text-muted">Adicione os itens que compõem o atendimento.</small>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" id="add-service-item">Adicionar item</button>
            </div>

            <div id="service-items-list">
              <% @order_service.service_items.each do |item| %>
                <div class="input-group mb-2">
                  <%= f.fields_for :service_items, item do |item_fields| %>
                    <%= item_fields.text_field :description, class: "form-control", placeholder: "Nome do item" %>
                    <%= item_fields.text_field :quantity, class: "form-control", placeholder: "Quantidade" %>
                    <%= item_fields.text_field :unit_price,
                                               class: "form-control",
                                               placeholder: "Valor unitário",
                                               data: { money_mask: "brl" } %>
                    <%= item_fields.hidden_field :_destroy, class: "service-item-destroy-flag" %>
                    <button type="button" class="btn btn-danger remove-item">Remover</button>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div id="service-item-template" style="display:none;">
          <div class="input-group mb-2 service-item-row">
            <input type="text"
                   name="order_service[service_items_attributes][NEW_INDEX][description]"
                   class="form-control"
                   placeholder="Nome do item" />
            <input type="text"
                   name="order_service[service_items_attributes][NEW_INDEX][quantity]"
                   class="form-control"
                   placeholder="Quantidade" />
            <input type="text"
                   name="order_service[service_items_attributes][NEW_INDEX][unit_price]"
                   class="form-control"
                   placeholder="Valor unitário"
                   data-money-mask="brl" />
            <button type="button" class="btn btn-danger remove-item">Remover</button>
          </div>
        </div>
      <% end %>

      <div class="col-12">
        <div class="pt-2">
          <%= f.submit "Salvar", class: "btn btn-primary px-4" %>
          <%= link_to "Voltar",
                      @order_service.persisted? ? app_order_service_path(@order_service) : app_order_services_path,
                      class: "btn btn-light px-4" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%= javascript_include_tag "app/order_service_attachments" %>
