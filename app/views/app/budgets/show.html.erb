<div class="page-wrapper">
  <div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3 justify-content-between">
      <h4 class="mb-0 text-uppercase">Detalhes do Orçamento</h4>
      <%= link_to "Gerar PDF", generate_pdf_app_budget_path(@budget), class: "btn btn-outline-secondary", target: "_blank" %>
    </div>

    <% flash.each do |type, message| %>
      <% bootstrap_class = { notice: "alert-success", alert: "alert-danger", error: "alert-danger" }[type.to_sym] || "alert-info" %>
      <div class="alert <%= bootstrap_class %> alert-dismissible fade show" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>

    <div class="card">
      <div class="card-body">
        <div class="row mb-3">
          <div class="col-md-4">
            <strong>Código:</strong>
            <p><%= @budget.code %></p>
          </div>
          <div class="col-md-4">
            <strong>Cliente:</strong>
            <p><%= @budget.client&.name %></p>
          </div>
          <div class="col-md-4">
            <strong>Status:</strong>
            <p><span class="badge bg-light text-dark border"><%= budget_status_label(@budget) %></span></p>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-6">
            <strong>Título:</strong>
            <p><%= @budget.title %></p>
          </div>
          <div class="col-md-6">
            <strong>Validade:</strong>
            <p><%= @budget.valid_until.present? ? l(@budget.valid_until) : "-" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-12">
            <strong>Descrição:</strong>
            <p><%= @budget.description.presence || "-" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-4">
            <strong>Valor total:</strong>
            <p><%= @budget.formatted_total_value %></p>
          </div>
          <div class="col-md-4">
            <strong>Enviado em:</strong>
            <p><%= @budget.approval_sent_at.present? ? l(@budget.approval_sent_at, format: :short) : "-" %></p>
          </div>
          <div class="col-md-4">
            <strong>Aprovado em:</strong>
            <p><%= @budget.approved_at.present? ? l(@budget.approved_at, format: :short) : "-" %></p>
          </div>
        </div>

        <% if @budget.rejection_reason.present? %>
          <div class="row mb-3">
            <div class="col-md-12">
              <strong>Motivo da rejeição:</strong>
              <p><%= @budget.rejection_reason %></p>
            </div>
          </div>
        <% end %>

        <hr>
        <h5>Itens do Serviço</h5>
        <% if @budget.service_items.any? %>
          <table class="table table-bordered">
            <thead>
              <tr>
                <th>Descrição</th>
                <th>Quantidade</th>
                <th>Valor Unitário</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              <% @budget.service_items.each do |item| %>
                <tr>
                  <td><%= item.description %></td>
                  <td><%= item.quantity %></td>
                  <td><%= currency_br(item.unit_price) %></td>
                  <td><%= currency_br(item.quantity.to_d * item.unit_price.to_d) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p>Nenhum item cadastrado para este orçamento.</p>
        <% end %>

        <div class="mt-3 d-flex justify-content-between align-items-center">
          <div>
            <%= link_to "Voltar", app_budgets_path, class: "btn btn-secondary" %>
            <% if @budget.editable? %>
              <%= link_to "Editar", edit_app_budget_path(@budget), class: "btn btn-primary" %>
            <% end %>
            <% if @budget.order_service.present? %>
              <%= link_to "Ver OS vinculada", app_order_service_path(@budget.order_service), class: "btn btn-outline-primary ms-2" %>
            <% end %>
          </div>

          <div>
            <% if @budget.rascunho? || @budget.rejeitado? %>
              <%= button_to "Enviar ao cliente",
                            send_for_approval_app_budget_path(@budget),
                            method: :post,
                            form_class: "d-inline-block",
                            class: "btn btn-outline-primary ms-2" %>
            <% end %>

            <% if @budget.enviado? || @budget.rascunho? || @budget.rejeitado? %>
              <%= button_to "Aprovar (Gestor)",
                            approve_app_budget_path(@budget),
                            method: :patch,
                            form_class: "d-inline-block",
                            class: "btn btn-success ms-2",
                            data: { confirm: "Aprovar orçamento e criar OS automaticamente com status pendente?" } %>

              <%= button_to "Rejeitar (Gestor)",
                            reject_app_budget_path(@budget),
                            method: :patch,
                            params: { rejection_reason: "Rejeitado pelo gestor." },
                            form_class: "d-inline-block",
                            class: "btn btn-outline-danger ms-2" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
