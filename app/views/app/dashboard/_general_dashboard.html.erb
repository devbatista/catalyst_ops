<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4">
  <div class="col">
    <div class="card radius-10 border-start border-0 border-4 border-info">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div>
            <p class="mb-0 text-secondary">Total de Ordens</p>
            <h4 class="my-1 text-info"><%= @order_services.count %></h4>
            <%= weekly_change_indicator(@orders_current_week, @orders_last_week) %>
          </div>
          <div class="widgets-icons-2 rounded-circle bg-gradient-blues text-white ms-auto">
            <i class='bx bxs-edit'></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card radius-10 border-start border-0 border-4 border-danger">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div>
            <p class="mb-0 text-secondary">
              <%= current_user.gestor? ? "Faturamento bruto" : "Valor geral dos itens" %>
            </p>
            <h4 class="my-1 text-danger">
              <%= currency_br(@total_revenue) %>
            </h4>
            <% if current_user.gestor? %>
              <p class="mb-0 font-13 text-secondary">Serviços lançados</p>
            <% else %>
              <%= weekly_change_indicator(@revenue_current_week, @revenue_last_week) %>
            <% end %>
          </div>
          <div class="widgets-icons-2 rounded-circle bg-gradient-burning text-white ms-auto"><i class='bx bxs-wallet'></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card radius-10 border-start border-0 border-4 border-success">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div>
            <p class="mb-0 text-secondary">Técnicos</p>
            <h4 class="my-1 text-success"><%= @technicians_count %></h4>
            <%= weekly_change_indicator(@new_technicians_current_week, @new_clients_last_week) %>
          </div>
          <div class="widgets-icons-2 rounded-circle bg-gradient-ohhappiness text-white ms-auto"><i class='bx bxs-bar-chart-alt-2'></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card radius-10 border-start border-0 border-4 border-warning">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div>
            <p class="mb-0 text-secondary">Total de clientes ativos</p>
            <h4 class="my-1 text-warning"><%= @clients_count %></h4>
            <%= weekly_change_indicator(@new_clients_current_week, @new_clients_last_week) %>
          </div>
          <div class="widgets-icons-2 rounded-circle bg-gradient-orange text-white ms-auto"><i class='bx bxs-group'></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12 col-lg-4 d-flex">
    <div class="card radius-10 w-100">
      <div class="card-header">
        <div class="d-flex align-items-center">
          <div>
            <h6 class="mb-0">Status de OS</h6>
          </div>
        </div>
      </div>
      <div class="card-body">
        <div class="chart-container-2">
          <canvas id="chart2"></canvas>
        </div>
      </div>
      <ul class="list-group list-group-flush" id="os-status-list">
        <% @order_services_by_status.each do |status, count| %>
          <% color_key = status_color_for(status) %>
          <li class="list-group-item d-flex bg-transparent justify-content-between align-items-center border-top"
              data-status="<%= status.to_s.humanize %>"
              data-count="<%= count %>"
              data-color-key="<%= color_key %>">
            <span class="os-status-label"><%= status.to_s.humanize %></span>
            <span class="badge rounded-pill os-status-count bg-<%= color_key %>">
              <%= count %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="col-12 col-lg-8 d-flex">
    <div class="card radius-10 w-100">
      <div class="card-header">
        <h6 class="mb-0">Pendentes de Finalização</h6>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Código</th>
                <th>Cliente</th>
                <th>Data Agendada</th>
                <th>Técnico(s)</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if @pending_approval_orders.any? %>
                <% @pending_approval_orders.each do |order| %>
                  <tr>
                    <td><%= order.code %></td>
                    <td><%= order.client.name %></td>
                    <td><%= l(order.created_at, format: :short) %></td>
                    <td><%= order.users.map(&:name).join(", ") %></td>
                    <td>
                      <%= link_to "Ver Detalhes", app_order_service_path(order), class: "btn btn-sm btn-outline-primary" %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="5" class="text-center">Nenhuma ordem de serviço concluída.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render "order_services" %>
