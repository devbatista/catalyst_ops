<% content_for :head do %>
  <%= stylesheet_link_tag "fullcalendar/main.min" %>
  <%= javascript_include_tag "fullcalendar/main.min", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "fullcalendar/locales/locales-all.min", "data-turbo-track": "reload" %>
<% end %>

<div class="page-wrapper invisible" data-controller="calendar">
  <div class="page-content">
    <div class="card">
      <div class="card-body">
        <div class="calendar-filter-card rounded-3 p-3 mb-3">
          <div class="row g-3 align-items-end">
            <div class="col-12 col-lg-6">
              <label for="calendar-technician-filter" class="form-label text-uppercase text-secondary fw-semibold small mb-2">
                Técnicos
              </label>
              <div class="input-group calendar-tech-filter-group">
                <span class="input-group-text bg-white calendar-tech-filter-icon">
                  <i class="bx bx-user"></i>
                </span>
                <select id="calendar-technician-filter"
                        class="form-select js-select2-technician-filter"
                        multiple
                        size="4"
                        data-placeholder="Escolha os técnicos"
                        data-calendar-target="technicianFilter">
                  <option value="" disabled>Carregando técnicos...</option>
                </select>
              </div>
            </div>

            <div class="col-12 col-lg-6">
              <div class="d-flex justify-content-lg-end">
                <small class="text-muted">Selecione um ou mais técnicos para filtrar os eventos.</small>
              </div>
            </div>
          </div>
        </div>

        <div class="table-responsive">
          <div id="calendar" data-calendar-target="calendar"></div>
        </div>
      </div>
    </div>
  </div>
</div>
