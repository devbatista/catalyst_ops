<%= form_with model: @admin_user,
              url: admin_configuration_path("profile"),
              method: :patch,
              local: true do |f| %>
  <div class="row g-3">
    <div class="col-12 col-xl-6">
      <%= f.label :name, "Nome", class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>

    <div class="col-12 col-xl-6">
      <%= f.label :email, "Email", class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: true %>
    </div>

    <div class="col-12 col-xl-6">
      <%= f.label :phone, "Telefone", class: "form-label" %>
      <%= f.text_field :phone, class: "form-control", data: { mask: "phone" } %>
    </div>

    <div class="col-12 col-xl-6 d-flex align-items-end">
      <div class="w-100">
        <small class="text-muted">Perfil administrador do ambiente.</small>
      </div>
    </div>

    <div class="col-12 col-md-6">
      <%= f.label :password, "Nova senha", class: "form-label" %>
      <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
      <small class="text-muted">Preencha apenas se quiser alterar.</small>
    </div>

    <div class="col-12 col-md-6">
      <%= f.label :password_confirmation, "Confirmar senha", class: "form-label" %>
      <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
    </div>

    <div class="col-12 d-flex gap-2">
      <%= f.submit "Salvar alterações", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
