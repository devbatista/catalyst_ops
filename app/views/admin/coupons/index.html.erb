<div class="page-wrapper">
  <div class="page-content">
    <div class="row">
      <div class="col-12">
        <div class="mb-3">
          <h4 class="mb-0 text-uppercase">Cupons</h4>
        </div>

        <div class="card">
          <div class="card-body">
            <div class="row align-items-center mb-4">
              <div class="col-12 col-md-6 d-flex flex-column flex-md-row align-items-stretch gap-2">
                <div class="showing-entries-group flex-shrink-0">
                  <span class="showing-entries-label">Mostrar</span>
                  <form method="get" class="showing-entries-form">
                    <select name="per" class="form-select form-select-sm showing-entries-select" onchange="this.form.submit()">
                      <% [10, 20, 30].each do |n| %>
                        <option value="<%= n %>" <%= params[:per].to_i == n ? 'selected' : '' %>><%= n %></option>
                      <% end %>
                    </select>
                    <input type="hidden" name="q" value="<%= params[:q] %>">
                    <input type="hidden" name="status" value="<%= params[:status] %>">
                    <input type="hidden" name="benefit_type" value="<%= params[:benefit_type] %>">
                  </form>
                  <span class="showing-entries-text">registros</span>
                </div>

                <form method="get" class="flex-grow-1" style="min-width: 0;">
                  <div class="input-group input-search-group">
                    <span class="input-group-text">
                      <i class="bx bx-search"></i>
                    </span>
                    <input type="text"
                           name="q"
                           value="<%= params[:q] %>"
                           class="form-control input-search"
                           placeholder="Buscar por código ou nome..."
                           aria-label="Buscar cupom">
                    <input type="hidden" name="per" value="<%= params[:per].presence || 10 %>">
                    <input type="hidden" name="status" value="<%= params[:status] %>">
                    <input type="hidden" name="benefit_type" value="<%= params[:benefit_type] %>">
                  </div>
                </form>
              </div>

              <div class="col-12 col-md-6 d-flex justify-content-md-end mt-3 mt-md-0">
                <div class="d-flex align-items-center gap-2">
                  <form method="get" class="d-flex align-items-center gap-2 mb-0">
                    <span class="showing-entries-label">Tipo</span>
                    <select name="benefit_type" class="form-select form-select-sm" onchange="this.form.submit()">
                      <option value="">Todos</option>
                      <% Coupon::BENEFIT_TYPES.each do |benefit_type| %>
                        <option value="<%= benefit_type %>" <%= 'selected' if params[:benefit_type] == benefit_type %>>
                          <%= benefit_type == 'trial' ? 'Teste' : 'Desconto' %>
                        </option>
                      <% end %>
                    </select>

                    <span class="showing-entries-label">Status</span>
                    <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                      <option value="">Todos</option>
                      <option value="active" <%= 'selected' if params[:status] == 'active' %>>Ativos</option>
                      <option value="inactive" <%= 'selected' if params[:status] == 'inactive' %>>Inativos</option>
                    </select>

                    <input type="hidden" name="q" value="<%= params[:q] %>">
                    <input type="hidden" name="per" value="<%= params[:per].presence || 10 %>">
                  </form>

                  <%= link_to raw('<i class="bx bx-plus"></i> Novo cupom'),
                              new_admin_coupon_path,
                              class: "btn btn-sm btn-outline-primary ms-2" %>
                </div>
              </div>
            </div>

            <div class="table-responsive">
              <table class="table mb-0 table-hover">
                <thead>
                  <tr>
                    <th>Código</th>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>Status</th>
                    <th>Validade</th>
                    <th>Resgates</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% @coupons.each do |coupon| %>
                    <tr>
                      <td><code><%= coupon.code %></code></td>
                      <td><%= coupon.name %></td>
                      <td>
                        <% if coupon.trial? %>
                          <span class="badge bg-info text-dark">Teste</span>
                        <% else %>
                          <span class="badge bg-primary">Desconto</span>
                        <% end %>
                      </td>
                      <td>
                        <% if coupon.active? %>
                          <span class="badge bg-success">Ativo</span>
                        <% else %>
                          <span class="badge bg-secondary">Inativo</span>
                        <% end %>
                      </td>
                      <td>
                        <% if coupon.valid_from.present? || coupon.valid_until.present? %>
                          <small>
                            <%= coupon.valid_from.present? ? l(coupon.valid_from, format: :short) : '-' %>
                            até
                            <%= coupon.valid_until.present? ? l(coupon.valid_until, format: :short) : '-' %>
                          </small>
                        <% else %>
                          <span class="text-muted">Sem período</span>
                        <% end %>
                      </td>
                      <td>
                        <%= coupon.redemptions_count %>
                        <% if coupon.max_redemptions.present? %>
                          / <%= coupon.max_redemptions %>
                        <% else %>
                          / ilimitado
                        <% end %>
                      </td>
                      <td>
                        <%= link_to 'Ver', admin_coupon_path(coupon), class: "btn btn-sm btn-primary" %>
                        <%= link_to 'Editar', edit_admin_coupon_path(coupon), class: "btn btn-sm btn-warning ms-2" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3">
              <div class="text-muted">
                Mostrando <%= @coupons.size %> de <%= @coupons.total_count %> registros
              </div>
              <nav aria-label="Page navigation">
                <%= custom_paginate(@coupons) %>
              </nav>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
