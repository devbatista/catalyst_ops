<div class="page-wrapper">
  <div class="page-content">
    <div class="row">
      <div class="col-12">
        <div class="mb-3">
          <h4 class="mb-0 text-uppercase">Planos</h4>
        </div>

        <div class="card">
          <div class="card-body">
            <div class="row align-items-center mb-4">
              <!-- Filtros (mostra + busca por nome/razão) -->
              <div class="col-12 col-md-6 d-flex flex-column flex-md-row align-items-stretch gap-2">
                <div class="showing-entries-group flex-shrink-0">
                  <span class="showing-entries-label">Mostrar</span>
                  <form method="get" class="showing-entries-form">
                    <select name="per" class="form-select form-select-sm showing-entries-select" onchange="this.form.submit()">
                      <% [10, 20, 30].each do |n| %>
                        <option value="<%= n %>" <%= params[:per].to_i == n ? 'selected' : '' %>><%= n %></option>
                      <% end %>
                    </select>
                    <input type="hidden" name="q" value="<%= params[:q] %>">
                    <input type="hidden" name="status" value="<%= params[:status] %>">
                  </form>
                  <span class="showing-entries-text">registros</span>
                </div>

                <!-- Busca -->
                <form method="get" class="flex-grow-1" style="min-width: 0;">
                  <div class="input-group input-search-group">
                    <span class="input-group-text">
                      <i class="bx bx-search"></i>
                    </span>
                    <input type="text"
                           name="q"
                           value="<%= params[:q] %>"
                           class="form-control input-search"
                           placeholder="Buscar por nome ou descrição..."
                           aria-label="Buscar plano">
                    <input type="hidden" name="per" value="<%= params[:per].presence || 10 %>">
                    <input type="hidden" name="status" value="<%= params[:status] %>">
                  </div>
                </form>
              </div>

              <!-- Filtro por status alinhado à direita -->
              <div class="col-12 col-md-6 d-flex justify-content-md-end mt-3 mt-md-0">
                <div class="d-flex align-items-center gap-2">
                  <form method="get" class="d-flex align-items-center gap-2 mb-0">
                    <span class="showing-entries-label">Status</span>
                    <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                      <option value="">Todos</option>
                      <option value="active"   <%= 'selected' if params[:status] == 'active' %>>Ativos</option>
                      <option value="inactive" <%= 'selected' if params[:status] == 'inactive' %>>Inativos</option>
                    </select>
                    <input type="hidden" name="q" value="<%= params[:q] %>">
                    <input type="hidden" name="per" value="<%= params[:per].presence || 10 %>">
                  </form>
              
                  <%= link_to raw('<i class="bx bx-plus"></i> Novo plano'),
                      new_admin_plan_path,
                      class: "btn btn-sm btn-outline-primary ms-2" %>
                </div>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table mb-0 table-hover">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Descrição</th>
                    <th>Status</th>
                    <th>Frequência</th>
                    <th>Valor</th>
                    <th>Máx. técnicos</th>
                    <th>Máx. OS/mês</th>
                    <th>Suporte</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% @plans.each do |plan| %>
                    <tr>
                      <td><%= plan.name %></td>
                      <td><%= plan.reason %></td>
                      <td>
                        <% if plan.status == "active" %>
                          <span class="badge bg-success">Ativo</span>
                        <% else %>
                          <span class="badge bg-secondary">Inativo</span>
                        <% end %>
                      </td>
                      <td><%= "#{plan.frequency} #{plan.frequency_type}" %></td>
                      <td>
                        R$ <%= number_with_precision(plan.transaction_amount,
                                                     precision: 2,
                                                     separator: ',',
                                                     delimiter: '.') %>
                      </td>
                      <td><%= plan.max_technicians.presence || "Ilimitado" %></td>
                      <td><%= plan.max_orders.presence || "Ilimitado" %></td>
                      <td><%= plan.support_level.presence || "-" %></td>
                      <td>
                        <%= link_to 'Ver', admin_plan_path(plan), class: "btn btn-sm btn-primary" %>
                        <%= link_to 'Editar', edit_admin_plan_path(plan), class: "btn btn-sm btn-warning ms-2" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3">
              <div class="text-muted">
                Mostrando <%= @plans.size %> de <%= @plans.total_count %> registros
              </div>
              <nav aria-label="Page navigation">
                <%= custom_paginate(@plans) %>
              </nav>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>