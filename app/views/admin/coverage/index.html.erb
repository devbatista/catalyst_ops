<div class="page-wrapper">
  <div class="page-content">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
      <div>
        <h4 class="mb-1 text-uppercase">Coverage</h4>
        <p class="text-muted mb-0">Resumo do relatório SimpleCov gerado pela suíte RSpec.</p>
      </div>

      <% if @coverage_report&.dig(:report_exists) %>
        <%= link_to "Abrir relatório completo",
                    @coverage_report_path,
                    class: "btn btn-sm btn-primary",
                    target: "_blank",
                    rel: "noopener" %>
      <% end %>
    </div>

    <% if @coverage_report.present? %>
      <div class="small text-muted mb-3">
        Última atualização: <%= l(@coverage_report[:updated_at], format: :short) %>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="text-muted small mb-1">Cobertura de linhas</div>
              <div class="fs-4 fw-semibold text-primary">
                <%= number_to_percentage(@coverage_report[:line], precision: 2) %>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="text-muted small mb-1">Cobertura de branches</div>
              <div class="fs-4 fw-semibold text-primary">
                <%= number_to_percentage(@coverage_report[:branch], precision: 2) %>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="text-muted small mb-1">Relatório HTML</div>
              <span class="badge <%= @coverage_report[:report_exists] ? "bg-success" : "bg-warning text-dark" %>">
                <%= @coverage_report[:report_exists] ? "disponível" : "não gerado" %>
              </span>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="text-muted small mb-1">Resultset</div>
              <span class="badge <%= @coverage_report[:resultset_exists] ? "bg-success" : "bg-secondary" %>">
                <%= @coverage_report[:resultset_exists] ? "presente" : "ausente" %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="mb-3">Relatório completo</h6>
          <% if @coverage_report[:report_exists] %>
            <div class="ratio ratio-16x9 border rounded">
              <iframe src="<%= @coverage_report_path %>" title="Relatório SimpleCov"></iframe>
            </div>
          <% else %>
            <p class="text-muted mb-0">O arquivo <code>coverage/index.html</code> ainda não foi encontrado.</p>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="mb-2">Relatório não encontrado</h6>
          <p class="text-muted mb-3">Rode a suíte RSpec para gerar os arquivos do SimpleCov.</p>
          <code>rbenv exec bundle exec rspec</code>
        </div>
      </div>
    <% end %>
  </div>
</div>
