<div class="page-wrapper">
  <div class="page-content">
    <div class="row">
      <div class="col-12 col-lg-10 col-xl-8 mx-auto">
        <div class="mb-3">
          <%= link_to "← Voltar", admin_knowledge_base_index_path, class: "btn btn-light" %>
        </div>
        <div class="card">
          <div class="card-body">
            <h2 class="mb-2"><%= @article.title %></h2>
            <div class="mb-3 text-muted">
              <i class="bx bx-folder"></i>
              <%= @article.category.presence || "Sem categoria" %>
            </div>
            <hr>
            <div class="mb-3">
              <%= raw @article.content %>
            </div>
            <div class="d-flex gap-2">
              <%= link_to "Editar", edit_admin_knowledge_base_path(@article), class: "btn btn-secondary" %>
              <%= link_to "Excluir", admin_knowledge_base_path(@article), method: :delete, data: { confirm: "Tem certeza?" }, class: "btn btn-danger" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>