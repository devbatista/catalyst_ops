<%= form_with(
    model: @knowledge_base_article,
    url: @knowledge_base_article.persisted? ? admin_knowledge_base_path(@knowledge_base_article) : admin_knowledge_base_index_path,
    local: true
  ) do |form| %>
  <div class="mb-3">
    <%= form.label :title, "Título", class: "form-label" %>
    <%= form.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :category, "Categoria", class: "form-label" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-list"></i></span>
      <%= form.text_field :category, class: "form-control", required: true, list: "categories-list", autocomplete: "off", placeholder: "Escolha ou digite uma categoria" %>
    </div>
    <datalist id="categories-list">
      <% @all_categories&.each do |cat| %>
        <option value="<%= cat %>">
      <% end %>
    </datalist>
  </div>

  <div class="mb-3">
    <%= form.label :content, "Conteúdo (Markdown)", class: "form-label" %>
    <%= form.text_area :content, class: "form-control", rows: 10, required: true %>
  </div>

  <div class="d-flex justify-content-between">
    <%= link_to "Voltar", admin_knowledge_base_index_path, class: "btn btn-secondary" %>
    <%= form.submit(@knowledge_base_article.new_record? ? "Criar Artigo" : "Atualizar Artigo", class: "btn btn-primary") %>
  </div>
<% end %>