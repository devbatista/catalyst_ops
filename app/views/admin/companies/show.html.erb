<div class="page-wrapper">
  <div class="page-content">
    <div class="row">
      <div class="col-12">
        <div class="mb-3">
          <h4 class="mb-0 text-uppercase">Informações da empresa</h4>
        </div>

        <div class="card">
          <div class="card-body">
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Nome:</strong>
                <p><%= @company.name %></p>
              </div>
              <div class="col-md-3">
                <strong>Documento:</strong>
                <p><%= @company.formatted_document %></p>
              </div>
              <div class="col-md-3">
                <strong>Telefone:</strong>
                <p><%= @company.formatted_phone %></p>
              </div>
            </div>

            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Email:</strong>
                <p><%= @company.email %></p>
              </div>
              <div class="col-md-6">
                <strong>Website:</strong>
                <p>
                  <% if @company.website.present? %>
                    <%= link_to @company.website, @company.website, target: "_blank", rel: "noopener" %>
                  <% else %>
                    <span class="text-muted">Não informado</span>
                  <% end %>
                </p>
              </div>
            </div>

            <hr>

            <h5>Endereço</h5>
            <div class="row mb-2">
              <div class="col-md-3">
                <strong>CEP:</strong>
                <p><%= @company.formatted_zip_code %></p>
              </div>
              <div class="col-md-5">
                <strong>Rua / Número / Compl.:</strong>
                <p><%= @company.full_address %></p>
              </div>
              <div class="col-md-4">
                <strong>Bairro:</strong>
                <p><%= @company.neighborhood %></p>
              </div>
            </div>

            <div class="row mb-3">
              <div class="col-md-4">
                <strong>Cidade:</strong>
                <p><%= @company.city %></p>
              </div>
              <div class="col-md-2">
                <strong>UF:</strong>
                <p><%= @company.state %></p>
              </div>
              <div class="col-md-3">
                <strong>Inscrição Estadual:</strong>
                <p><%= @company.state_registration.presence || "-" %></p>
              </div>
              <div class="col-md-3">
                <strong>Inscrição Municipal:</strong>
                <p><%= @company.municipal_registration.presence || "-" %></p>
              </div>
            </div>

            <hr>

            <h5>Plano e Status</h5>
            <div class="row mb-3">
              <div class="col-md-4">
                <strong>Plano atual:</strong>
                <p><%= @company.current_plan&.name || @company.plan&.name || "Sem plano" %></p>
              </div>
              <div class="col-md-4">
                <strong>Forma de pagamento:</strong>
                <p><%= @company.payment_method&.humanize || "-" %></p>
              </div>
              <div class="col-md-4">
                <strong>Status de acesso:</strong>
                <p>
                  <% if @company.access_enabled? %>
                    <span class="badge bg-success">Acesso ativo</span>
                  <% elsif @company.active? %>
                    <span class="badge bg-warning text-dark">Ativa (sem assinatura)</span>
                  <% else %>
                    <span class="badge bg-secondary">Inativa</span>
                  <% end %>
                </p>
              </div>
            </div>

            <hr>

            <h5>Responsável</h5>
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Responsável:</strong>
                <p><%= @company.responsible&.name || "Não definido" %></p>
              </div>
              <div class="col-md-6">
                <strong>Email do responsável:</strong>
                <p><%= @company.responsible&.email || "-" %></p>
              </div>
            </div>

            <hr>
            
            <h5>Usuários vinculados</h5>
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Gestores</strong>
                <% gestores = @company.users.gestores %>
                <% if gestores.any? %>
                  <ul class="mt-2">
                    <% gestores.each do |user| %>
                      <li>
                        <%= link_to user.full_name, admin_user_path(user), class: "link-light" %>
                        (<%= user.email %>)
                        <% if user.active? %>
                          <span class="badge bg-success ms-1">Ativo</span>
                        <% else %>
                          <span class="badge bg-secondary ms-1">Inativo</span>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="text-muted mt-2 mb-0">Nenhum gestor vinculado.</p>
                <% end %>
              </div>
            
              <div class="col-md-6">
                <strong>Técnicos</strong>
                <% tecnicos = @company.users.tecnicos %>
                <% if tecnicos.any? %>
                  <ul class="mt-2">
                    <% tecnicos.each do |user| %>
                      <li>
                        <%= link_to user.full_name, admin_user_path(user), class: "link-light" %>
                        (<%= user.email %>)
                        <% if user.active? %>
                          <span class="badge bg-success ms-1">Ativo</span>
                        <% else %>
                          <span class="badge bg-secondary ms-1">Inativo</span>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="text-muted mt-2 mb-0">Nenhum técnico vinculado.</p>
                <% end %>
              </div>
            </div>

            <hr>
            
            <h5>Tickets de suporte</h5>
            
            <% if @tickets.present? %>
              <div class="table-responsive mb-3">
                <table class="table table-hover align-middle">
                  <thead>
                    <tr>
                      <th>Código</th>
                      <th>Assunto</th>
                      <th>Cliente</th>
                      <th>Status</th>
                      <th>Impacto</th>
                      <th>Atualizado em</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @tickets.each do |ticket| %>
                      <tr>
                        <td><%= ticket.id %></td>
                        <td><%= truncate(ticket.subject, length: 60) %></td>
                        <td><%= ticket.user&.full_name || ticket.user&.name %></td>
                        <td>
                          <% status_class =
                               case ticket.status.to_sym
                               when :aberto              then "secondary"
                               when :em_andamento        then "info"
                               when :aguardando_cliente  then "warning"
                               when :resolvido           then "success"
                               when :fechado, :cancelado then "dark"
                               else "secondary"
                               end %>
                          <span class="badge bg-<%= status_class %>">
                            <%= ticket.status.humanize %>
                          </span>
                        </td>
                        <td>
                          <% impact_class =
                               case ticket.impact.to_sym
                               when :bloqueante then "danger"
                               when :alto       then "warning"
                               when :medio      then "info"
                               else "secondary"
                               end %>
                          <span class="badge bg-<%= impact_class %>">
                            <%= ticket.impact.humanize %>
                          </span>
                        </td>
                        <td><%= l(ticket.last_reply_at || ticket.created_at, format: :short) %></td>
                        <td class="text-end">
                          <%= link_to "Ver", admin_ticket_path(ticket), class: "btn btn-sm btn-primary" %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            
              <%= link_to "Ver todos os tickets", admin_tickets_path(q: @company.name), class: "btn btn-outline-secondary btn-sm" %>
            <% else %>
              <p class="text-muted">Esta empresa ainda não possui tickets de suporte.</p>
            <% end %>            

            <div class="mt-3">
              <%= link_to "Voltar", admin_companies_path, class: "btn btn-secondary" %>
              <%# Quando tiver edição no admin, pode habilitar: %>
              <%#= link_to "Editar", edit_admin_company_path(@company), class: "btn btn-primary" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>