<div class="container py-5">
  <% flash.each do |type, message| %>
    <% bootstrap_class = { notice: "alert-success", alert: "alert-danger", error: "alert-danger" }[type.to_sym] || "alert-info" %>
    <div class="alert <%= bootstrap_class %> shadow-sm" role="alert">
      <%= message %>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-dark text-white py-3 px-4">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
        <div>
          <h3 class="h5 mb-1">Aprovação de Orçamento</h3>
          <small class="text-white-50">Revise os dados antes de aprovar ou rejeitar.</small>
        </div>
        <span class="badge text-bg-light px-3 py-2">ORC #<%= @budget.code %></span>
      </div>
    </div>

    <div class="card-body p-4">
      <div class="row g-3 mb-4">
        <div class="col-12 col-md-6">
          <div class="p-3 bg-light rounded-3 h-100">
            <div class="small text-muted mb-1">Cliente</div>
            <div class="fw-semibold"><%= @budget.client&.name %></div>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <div class="p-3 bg-light rounded-3 h-100">
            <div class="small text-muted mb-1">Empresa</div>
            <div class="fw-semibold"><%= @budget.company&.name %></div>
          </div>
        </div>
      </div>

      <div class="mb-4">
        <p class="mb-1"><strong>Título:</strong> <%= @budget.title %></p>
        <p class="mb-1"><strong>Descrição:</strong> <%= @budget.description %></p>
        <p class="mb-1"><strong>Criado em:</strong> <%= l(@budget.created_at.to_date, format: "%d/%m/%Y") %></p>
        <% if @budget.valid_until.present? %>
          <p class="mb-1"><strong>Prazo de resposta:</strong> <%= l(@budget.valid_until, format: "%d/%m/%Y") %></p>
        <% end %>
      </div>

      <div class="mb-4">
        <h4 class="h6 text-uppercase text-muted mb-2">Itens do Orçamento</h4>
        <% if @budget.service_items.any? %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Descrição</th>
                  <th class="text-end">Qtd.</th>
                  <th class="text-end">Valor unitário</th>
                  <th class="text-end">Total</th>
                </tr>
              </thead>
              <tbody>
                <% @budget.service_items.order(:created_at).each do |item| %>
                  <tr>
                    <td><%= item.description %></td>
                    <td class="text-end"><%= item.quantity %></td>
                    <td class="text-end"><%= number_to_currency(item.unit_price, unit: "R$ ", separator: ",", delimiter: ".") %></td>
                    <td class="text-end"><%= number_to_currency(item.quantity * item.unit_price, unit: "R$ ", separator: ",", delimiter: ".") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="mt-3 text-end fs-5 fw-semibold">
            Total: <%= number_to_currency(@budget.total_value, unit: "R$ ", separator: ",", delimiter: ".") %>
          </div>
        <% else %>
          <div class="alert alert-secondary mb-0">Este orçamento não possui itens cadastrados.</div>
        <% end %>
      </div>

      <% if @budget.approved_at.present? %>
        <div class="alert alert-success mb-0">Este orçamento já foi aprovado.</div>
      <% elsif @budget.rejected_at.present? %>
        <div class="alert alert-warning mb-0">
          Este orçamento foi rejeitado e aguarda revisão do gestor.
          <% if @budget.rejection_reason.present? %>
            <hr>
            <strong>Motivo informado:</strong> <%= @budget.rejection_reason %>
          <% end %>
        </div>
      <% else %>
        <div class="border rounded-3 p-3 bg-light">
          <h4 class="h6 text-uppercase text-muted mb-3">Responder orçamento</h4>

          <div class="d-flex flex-column flex-md-row gap-2 mb-3">
            <%= button_to "Aprovar",
                          approve_budget_approval_path(token: params[:token], subdomain: "cliente"),
                          method: :patch,
                          class: "btn btn-success px-4",
                          data: { confirm: "Confirma a aprovação deste Orçamento?" } %>
            <button type="button" id="show-rejection-form" class="btn btn-outline-danger px-4">
              Rejeitar
            </button>
          </div>

          <div class="border rounded-3 p-3 bg-white d-none" id="rejection-form-wrapper">
            <%= form_with url: reject_budget_approval_path(token: params[:token], subdomain: "cliente"),
                          method: :patch,
                          local: true,
                          html: { id: "rejection-form" } do %>
              <div class="mb-2">
                <label for="rejection_reason" class="form-label fw-semibold">Motivo da rejeição</label>
                <textarea id="rejection_reason"
                          name="rejection_reason"
                          class="form-control"
                          rows="3"
                          required
                          minlength="5"
                          placeholder="Descreva o motivo da rejeição"></textarea>
              </div>
              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-outline-danger">Confirmar rejeição</button>
                <button type="button" id="hide-rejection-form" class="btn btn-light">Cancelar</button>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%= javascript_include_tag "cliente/budget_approvals" %>
