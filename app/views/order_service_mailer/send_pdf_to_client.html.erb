<h2 style="margin:0 0 16px 0; font-size:24px; line-height:1.3;">
  Olá, <%= @client.name %>!
</h2>

<p style="margin:0 0 18px 0; font-size:15px; line-height:1.7; color:#333;">
  Segue em anexo o PDF da sua Ordem de Serviço
  <strong>#<%= @order_service.code %></strong>.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="border-collapse:separate; border-spacing:0; margin:0 0 20px 0; border:1px solid #e8edf5; border-radius:8px; overflow:hidden;">
  <tr>
    <td style="background:#f8fafe; padding:12px 14px; font-size:13px; color:#5b6472; font-weight:600; text-transform:uppercase; letter-spacing:.4px;">
      Resumo do Envio
    </td>
  </tr>
  <tr>
    <td style="padding:14px; font-size:14px; color:#2f3640; line-height:1.7;">
      <strong>Empresa:</strong> <%= @order_service.company.name %><br>
      <strong>Cliente:</strong> <%= @client.name %><br>
      <strong>OS:</strong> #<%= @order_service.code %><br>
      <strong>Data de envio:</strong> <%= l(Time.current, format: :short) %><br>
      <strong>Responsável:</strong> <%= @sender.name %>
    </td>
  </tr>
</table>

<p style="margin:0; font-size:13px; line-height:1.7; color:#6b7280;">
  Se você tiver qualquer dúvida sobre os detalhes da ordem de serviço, responda este e-mail.
</p>
