<title>Nova mensagem no ticket</title>
<h2 style="margin-top:0;">Nova mensagem no ticket #<%= @ticket.id %></h2>

<p style="font-size:16px; line-height:1.6;">
  <strong>Empresa:</strong> <%= @company.name %><br>
  <strong>Assunto:</strong> <%= @ticket.subject %><br>
  <strong>Autor da mensagem:</strong> <%= @actor.full_name.presence || @actor.name %><br>
  <strong>Status atual:</strong> <%= @ticket.status.humanize %>
</p>

<p style="font-size:16px; line-height:1.6;">
  <strong>Mensagem:</strong><br>
  <%= simple_format(@support_message.body) %>
</p>

<div style="margin:32px 0;">
  <a href="<%= @ticket_url %>" target="_blank" style="background:#0d6efd; color:#fff; text-decoration:none; padding:14px 32px; border-radius:4px; font-size:16px; font-weight:bold; display:inline-block;">
    Acompanhar ticket
  </a>
</div>
