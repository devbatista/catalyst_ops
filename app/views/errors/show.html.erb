<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= @status_code %> - CatalystOps</title>
  <link rel="icon" href="<%= asset_path("favicon-32x32.png") %>" type="image/png">
  <style>
    :root {
      color-scheme: dark;
      --bg: #070d0e;
      --panel: #12181a;
      --line: rgba(255, 255, 255, 0.12);
      --text: #e4e5e6;
      --muted: #9ea4aa;
      --primary: #0d6efd;
      --primary-hover: #0b5ed7;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: Roboto, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: radial-gradient(circle at top, #102033 0%, var(--bg) 48%);
      color: var(--text);
      display: grid;
      place-items: center;
      padding: 24px;
    }

    .error-card {
      width: 100%;
      max-width: 560px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 32px 28px;
      box-shadow: 0 14px 35px rgba(0, 0, 0, 0.32);
    }

    .logo-wrap {
      margin-bottom: 20px;
      text-align: center;
    }

    .logo-wrap img {
      width: 140px;
      height: auto;
      filter: invert(1) grayscale(100%) brightness(180%);
    }

    .code {
      display: inline-block;
      font-size: 13px;
      letter-spacing: .08em;
      text-transform: uppercase;
      background: rgba(13, 110, 253, .18);
      border: 1px solid rgba(13, 110, 253, .35);
      color: #8ebcff;
      border-radius: 999px;
      padding: 6px 10px;
      margin-bottom: 14px;
    }

    h1 {
      margin: 0 0 10px;
      font-size: 28px;
      line-height: 1.2;
    }

    p {
      margin: 0;
      color: var(--muted);
      line-height: 1.5;
    }

    .actions {
      display: flex;
      gap: 12px;
      margin-top: 24px;
      flex-wrap: wrap;
    }

    .btn {
      border: 1px solid var(--line);
      border-radius: 10px;
      color: var(--text);
      padding: 10px 14px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
    }

    .btn-primary {
      background: var(--primary);
      border-color: var(--primary);
      color: #fff;
    }

    .btn-primary:hover {
      background: var(--primary-hover);
      border-color: var(--primary-hover);
    }
  </style>
</head>
<body>
  <main class="error-card">
    <div class="logo-wrap">
      <%= image_tag "logo-icon.png", alt: "CatalystOps" %>
    </div>

    <span class="code">Erro <%= @status_code %></span>
    <h1><%= @status_title %></h1>
    <p><%= @status_message %></p>

    <div class="actions">
      <a class="btn btn-primary" href="/">Voltar ao início</a>
      <a class="btn" href="javascript:history.back()">Página anterior</a>
    </div>
  </main>
</body>
</html>
